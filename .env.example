# OpenAI API Key (required for OpenAI instrumentation)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (required for Anthropic instrumentation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OTLP Endpoint (base URL only — the SDK appends /v1/traces automatically)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# OTLP Protocol (optional: "http" or "grpc", defaults to http)
# OTEL_EXPORTER_OTLP_PROTOCOL=http

# OTLP Headers (optional, for authenticated endpoints)
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer your-token

# Dashboard auth (required for dashboard/)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
